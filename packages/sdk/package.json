{
  "name": "logsneat",
  "version": "0.1.0",
  "description": "Drop-in observability SDK for AI agents — trace workflows, tools, retrieval and LLM calls, built on OpenTelemetry.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "observability",
    "tracing",
    "opentelemetry",
    "otel",
    "llm",
    "ai-agents",
    "openai",
    "logsneat"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karthiknadar1204/mini-agnost-ai.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/karthiknadar1204/mini-agnost-ai#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@arizeai/openinference-instrumentation-openai": "^4.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.41.0"
  },
  "peerDependencies": {
    "openai": "*"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "5.7.3"
  }
}
